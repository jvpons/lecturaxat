<!DOCTYPE html>
<html lang="ca">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Club de Lectura d'Estiu</title>
  <meta name="description" content="Espai on els alumnes compartixen llibres, opinen i comenten les seues lectures d'estiu.">
  <meta name="theme-color" content="#ff7675">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🏖️</text></svg>">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Fredoka:wght@500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <script>
    tailwind.config={theme:{extend:{fontFamily:{display:['Fredoka','sans-serif'],body:['Nunito','sans-serif']}}}}
  </script>
  <style>
    :root{--bg:#fffaf0;--bg-deep:#fef3e2;--fg:#2d3436;--muted:#636e72;--accent:#ff7675;--accent-h:#d63031;--accent-l:#ffeaa7;--green:#00b894;--green-l:#e0f7f0;--card:#ffffff;--border:#dfe6e9;--shadow:rgba(0,0,0,.06);--shadow-lg:rgba(0,0,0,.1)}
    *{box-sizing:border-box;margin:0}
    body{font-family:'Nunito',sans-serif;background:var(--bg);color:var(--fg);min-height:100vh}
    /* Fons d'estiu amb ones */
    body::before{content:'';position:fixed;bottom:0;left:0;right:0;height:250px;background:linear-gradient(to top, rgba(0,184,148,0.05) 0%, transparent 100%);pointer-events:none;z-index:0}
    body::after{content:'';position:fixed;top:0;left:0;right:0;height:250px;background:linear-gradient(to bottom, rgba(255,118,117,0.06) 0%, transparent 100%);pointer-events:none;z-index:0}
    .fd{font-family:'Fredoka',sans-serif}
    .star-r .s{cursor:pointer;font-size:1.5rem;color:var(--border);transition:color .15s,transform .15s;user-select:none}
    .star-r .s:hover,.star-r .s.on{color:#fdcb6e;transform:scale(1.2)}
    .star-r .s.hov{color:#ffeaa7}
    .pc{background:var(--card);border:2px solid var(--border);border-radius:1.25rem;box-shadow:0 4px 15px var(--shadow);transition:box-shadow .3s,transform .3s,border-color .3s}
    .pc:hover{box-shadow:0 8px 25px var(--shadow-lg);transform:translateY(-3px);border-color:var(--accent)}
    .bp{background:var(--accent);color:#fff;border:none;padding:.85rem 1.75rem;border-radius:1rem;font-family:'Fredoka',sans-serif;font-weight:600;font-size:1.05rem;cursor:pointer;transition:background .2s,transform .15s,box-shadow .2s;box-shadow:0 4px 15px rgba(255,118,117,.4);display:inline-flex;align-items:center;justify-content:center;gap:.5rem}
    .bp:hover{background:var(--accent-h);transform:translateY(-2px);box-shadow:0 6px 20px rgba(255,118,117,.5)}
    .bp:active{transform:translateY(0)}
    .bp:disabled{opacity:.6;cursor:not-allowed;transform:none!important;box-shadow:none!important}
    .bs{background:var(--green);color:#fff;border:none;padding:.55rem 1.25rem;border-radius:.8rem;font-weight:700;font-size:.875rem;cursor:pointer;transition:background .2s,transform .15s}
    .bs:hover{background:#00a884;transform:translateY(-1px)}
    .inp{width:100%;padding:.85rem 1.1rem;border:2px solid var(--border);border-radius:1rem;background:var(--card);font-family:'Nunito',sans-serif;font-size:1rem;color:var(--fg);transition:border-color .2s,box-shadow .2s;outline:none}
    .inp:focus{border-color:var(--green);box-shadow:0 0 0 3px rgba(0,184,148,.15)}
    .inp::placeholder{color:#b2bec3}
    textarea.inp{resize:vertical;min-height:100px}
    .uz{border:3px dashed var(--border);border-radius:1.25rem;padding:2rem;text-align:center;cursor:pointer;transition:border-color .2s,background .2s;background:var(--bg-deep);overflow:hidden;position:relative}
    .uz:hover,.uz.dov{border-color:var(--green);background:var(--green-l)}
    .uz img{max-height:200px;border-radius:.75rem;object-fit:contain}
    .uz input[type="file"]{position:absolute;inset:0;opacity:0;cursor:pointer}
    .lb:active{transform:scale(1.3)}.lb{transition:transform .15s;cursor:pointer}
    .lb.on{color:var(--accent)}
    .tc{position:fixed;top:1.5rem;right:1.5rem;z-index:9999;display:flex;flex-direction:column;gap:.5rem;pointer-events:none}
    .tt{padding:.85rem 1.25rem;border-radius:1rem;color:#fff;font-weight:700;font-size:.9rem;box-shadow:0 4px 16px rgba(0,0,0,.15);animation:ti .35s ease-out,to .35s ease-in 2.5s forwards;max-width:340px;pointer-events:auto}
    .tt.ok{background:var(--green)}.tt.er{background:var(--accent)}.tt.in{background:#0984e3}
    @keyframes ti{from{opacity:0;transform:translateX(60px)}to{opacity:1;transform:translateX(0)}}
    @keyframes to{from{opacity:1;transform:translateX(0)}to{opacity:0;transform:translateX(60px)}}
    .mo{position:fixed;inset:0;background:rgba(45,52,54,.6);backdrop-filter:blur(8px);z-index:1000;display:flex;align-items:center;justify-content:center;padding:1rem;animation:fi .25s ease-out}
    .mc{background:var(--card);border-radius:1.5rem;max-width:700px;width:100%;max-height:90vh;overflow-y:auto;animation:si .3s ease-out;box-shadow:0 25px 60px rgba(0,0,0,.2);border:2px solid var(--border)}
    @keyframes fi{from{opacity:0}to{opacity:1}}
    @keyframes si{from{opacity:0;transform:scale(.9)}to{opacity:1;transform:scale(1)}}
    .ci{border-left:4px solid var(--border);padding-left:1rem;transition:border-color .2s}
    .ci:hover{border-left-color:var(--green)}
    .pe{animation:ps .4s ease-out}
    @keyframes ps{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
    .fc{padding:.5rem 1.1rem;border-radius:2rem;font-size:.85rem;font-weight:700;border:2px solid var(--border);background:var(--card);cursor:pointer;transition:all .2s;white-space:nowrap}
    .fc:hover{border-color:var(--green);color:var(--green)}
    .fc.on{background:var(--green);border-color:var(--green);color:#fff}
    .sn{font-family:'Fredoka',sans-serif;font-weight:700;font-size:2.5rem;line-height:1;color:var(--accent)}
    ::-webkit-scrollbar{width:8px}::-webkit-scrollbar-track{background:var(--bg-deep)}::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px}::-webkit-scrollbar-thumb:hover{background:var(--muted)}
    .fp{position:fixed;pointer-events:none;z-index:0;opacity:.08;font-size:2rem;animation:fl 25s infinite linear}
    @keyframes fl{0%{transform:translateY(100vh) rotate(0deg)}100%{transform:translateY(-100px) rotate(360deg)}}
    .sd{width:8px;height:8px;border-radius:50%;display:inline-block;transition:background .3s;flex-shrink:0}
    .sd.ok{background:var(--green)}.sd.ld{background:#fdcb6e;animation:pu 1s infinite}.sd.er{background:var(--accent)}
    @keyframes pu{0%,100%{opacity:1}50%{opacity:.3}}
    .pass-err{color:var(--accent);font-size:.8rem;font-weight:700;margin-top:.5rem;text-align:center}
    @media(max-width:640px){.sn{font-size:1.75rem}}
    @media(prefers-reduced-motion:reduce){*,*::before,*::after{animation-duration:.01ms!important;transition-duration:.01ms!important}}
  </style>
</head>
<body class="relative">

  <!-- Partícules d'estiu -->
  <div id="ptc" aria-hidden="true"></div>
  
  <!-- Toasts -->
  <div class="tc" id="toasts"></div>

  <!-- ═══════ PORTA D'ACCÉS ═══════ -->
  <div id="accessGate" class="mo" style="z-index:3000">
    <div class="mc p-8 max-w-sm text-center">
      <div class="text-6xl mb-4">🏖️</div>
      <h2 class="fd text-3xl mb-1" style="color:var(--fg)">Club de Lectura d'Estiu</h2>
      <p class="text-sm mb-6" style="color:var(--muted)">Introdueix la contrasenya per entrar.</p>
      <input type="password" id="accessPass" class="inp mb-2" placeholder="Contrasenya d'accés..." autocomplete="off">
      <p class="pass-err hidden" id="accessErr">Contrasenya incorrecta. Torna a intentar-ho.</p>
      <button id="accessBtn" class="bp w-full mt-4"><i class="fa-solid fa-umbrella-beach"></i><span>Entrar al Club</span></button>
    </div>
  </div>

  <!-- ═══════ MODAL CREAR ═══════ -->
  <div id="mCreate" class="mo" style="display:none" role="dialog" aria-label="Nova publicació">
    <div class="mc p-6 sm:p-8">
      <div class="flex items-center justify-between mb-6">
        <h2 class="fd text-2xl font-bold" style="color:var(--green)"><i class="fa-solid fa-book-open mr-2"></i>Comparteix la teua lectura</h2>
        <button id="btnCloseModal" class="w-10 h-10 rounded-full flex items-center justify-center hover:bg-gray-100 transition" aria-label="Tancar"><i class="fa-solid fa-xmark text-lg" style="color:var(--muted)"></i></button>
      </div>
      <form id="pForm" novalidate>
        <div class="mb-4">
          <label class="block text-sm font-bold mb-1.5" style="color:var(--muted)">El teu nom <span style="color:var(--accent)">*</span></label>
          <input type="text" id="fName" class="inp" placeholder="Ex: Maria García" required maxlength="50">
          <p class="text-xs mt-1 hidden" style="color:var(--accent)" id="errName">Escriu el teu nom per continuar</p>
        </div>
        <div class="mb-4">
          <label class="block text-sm font-bold mb-1.5" style="color:var(--muted)">Títol del llibre <span style="color:var(--accent)">*</span></label>
          <input type="text" id="fTitle" class="inp" placeholder="Ex: L'illa del tresor" required maxlength="120">
          <p class="text-xs mt-1 hidden" style="color:var(--accent)" id="errTitle">El títol del llibre és obligatori</p>
        </div>
        <div class="mb-4">
          <label class="block text-sm font-bold mb-1.5" style="color:var(--muted)">Autor/a del llibre <span class="font-normal">(opcional)</span></label>
          <input type="text" id="fAuthor" class="inp" placeholder="Ex: Robert Louis Stevenson" maxlength="80">
        </div>
        <div class="mb-4">
          <label class="block text-sm font-bold mb-1.5" style="color:var(--muted)">La teua puntuació</label>
          <div class="star-r flex gap-1" id="stars" role="radiogroup" aria-label="Puntuació">
            <span class="s" data-v="1" role="radio" tabindex="0" aria-label="1 estrella"><i class="fa-solid fa-star"></i></span>
            <span class="s" data-v="2" role="radio" tabindex="0" aria-label="2 estrelles"><i class="fa-solid fa-star"></i></span>
            <span class="s" data-v="3" role="radio" tabindex="0" aria-label="3 estrelles"><i class="fa-solid fa-star"></i></span>
            <span class="s" data-v="4" role="radio" tabindex="0" aria-label="4 estrelles"><i class="fa-solid fa-star"></i></span>
            <span class="s" data-v="5" role="radio" tabindex="0" aria-label="5 estrelles"><i class="fa-solid fa-star"></i></span>
          </div>
        </div>
        <div class="mb-4">
          <label class="block text-sm font-bold mb-1.5" style="color:var(--muted)">Foto del llibre <span style="color:var(--accent)">*</span></label>
          <div class="uz" id="uZone">
            <input type="file" id="fImg" accept="image/*">
            <div id="uPh">
              <i class="fa-solid fa-camera text-3xl mb-2" style="color:var(--border)"></i>
              <p class="font-bold" style="color:var(--muted)">Arrosega la teua foto o fes clic</p>
              <p class="text-xs mt-1" style="color:var(--border)">JPG, PNG — Màxim 3MB</p>
            </div>
            <div id="uPv" class="hidden">
              <img id="pvImg" src="" alt="Vista prèvia">
              <p class="text-xs mt-2 font-bold" style="color:var(--green)"><i class="fa-solid fa-check-circle"></i> Imatge carregada</p>
            </div>
          </div>
          <p class="text-xs mt-1 hidden" style="color:var(--accent)" id="errImg">Puja una foto del llibre</p>
        </div>
        <div class="mb-6">
          <label class="block text-sm font-bold mb-1.5" style="color:var(--muted)">La teua opinió <span style="color:var(--accent)">*</span></label>
          <textarea id="fContent" class="inp" placeholder="Què t'ha semblat el llibre? T'ha agradat? Per què l'has triat per a l'estiu?" required maxlength="1000"></textarea>
          <div class="flex justify-between mt-1">
            <p class="text-xs hidden" style="color:var(--accent)" id="errContent">Escriu la teua opinió</p>
            <p class="text-xs ml-auto" style="color:var(--border)"><span id="cc">0</span>/1000</p>
          </div>
        </div>
        <button type="submit" class="bp w-full" id="submitBtn"><i class="fa-solid fa-paper-plane"></i><span>Publicar la meua opinió</span></button>
      </form>
    </div>
  </div>

  <!-- Modal imatge -->
  <div id="mImg" class="mo" style="display:none" role="dialog" aria-label="Veure imatge">
    <div class="relative max-w-3xl w-full mx-4">
      <button id="btnCloseImg" class="absolute -top-3 -right-3 w-10 h-10 rounded-full flex items-center justify-center text-white z-10" style="background:var(--accent)" aria-label="Tancar"><i class="fa-solid fa-xmark"></i></button>
      <img id="fullImg" src="" alt="Imatge completa" class="w-full rounded-2xl shadow-2xl">
    </div>
  </div>

  <!-- Header -->
  <header class="relative z-10 border-b-2" style="border-color:var(--accent-l);background:rgba(255,250,240,.9);backdrop-filter:blur(12px)">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-12 h-12 rounded-2xl flex items-center justify-center text-2xl" style="background:var(--accent-l)">☀️</div>
        <div>
          <h1 class="fd text-2xl sm:text-3xl leading-tight" style="color:var(--fg)">Club de Lectura d'Estiu</h1>
          <div class="flex items-center gap-2">
            <p class="text-xs font-bold" style="color:var(--muted)">Llegeix, opina i gaudeix! 🍦</p>
            <span class="sd ld" id="syncDot" title="Connectant..."></span>
          </div>
        </div>
      </div>
      <button id="btnNew" class="bp text-sm sm:text-base"><i class="fa-solid fa-plus"></i><span class="hidden sm:inline">Nova publicació</span><span class="sm:hidden">Publicar</span></button>
    </div>
  </header>

  <main class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 py-8">
    <section class="grid grid-cols-3 gap-3 sm:gap-6 mb-8" aria-label="Estadístiques">
      <div class="text-center p-4 sm:p-6 rounded-2xl" style="background:var(--card);border:2px solid var(--border)">
        <div class="sn" id="sB">0</div><p class="text-xs sm:text-sm font-bold mt-1" style="color:var(--muted)">Llibres compartits</p>
      </div>
      <div class="text-center p-4 sm:p-6 rounded-2xl" style="background:var(--card);border:2px solid var(--border)">
        <div class="sn" id="sC" style="color:var(--green)">0</div><p class="text-xs sm:text-sm font-bold mt-1" style="color:var(--muted)">Comentaris</p>
      </div>
      <div class="text-center p-4 sm:p-6 rounded-2xl" style="background:var(--card);border:2px solid var(--border)">
        <div class="sn" id="sL" style="color:#fdcb6e">0</div><p class="text-xs sm:text-sm font-bold mt-1" style="color:var(--muted)">M'agrada!</p>
      </div>
    </section>

    <section class="mb-6 flex flex-col sm:flex-row gap-3 items-stretch sm:items-center">
      <div class="relative flex-1">
        <i class="fa-solid fa-magnifying-glass absolute left-3.5 top-1/2 -translate-y-1/2" style="color:var(--border)"></i>
        <input type="text" id="search" class="inp pl-10" placeholder="Buscar per títol, autor o alumne...">
      </div>
      <div class="flex gap-2 overflow-x-auto pb-1" id="filters">
        <button class="fc on" data-f="all">Tots</button>
        <button class="fc" data-f="5"><i class="fa-solid fa-star text-xs mr-1" style="color:#fdcb6e"></i>5</button>
        <button class="fc" data-f="4+"><i class="fa-solid fa-star text-xs mr-1" style="color:#fdcb6e"></i>4+</button>
        <button class="fc" data-f="recent"><i class="fa-solid fa-clock text-xs mr-1"></i>Recents</button>
        <button class="fc" data-f="popular"><i class="fa-solid fa-fire text-xs mr-1" style="color:var(--accent)"></i>Populars</button>
      </div>
    </section>

    <section id="feed" aria-label="Publicacions">
      <div id="empty" class="text-center py-20 hidden">
        <div class="text-6xl mb-6">📚</div>
        <h3 class="fd text-2xl font-bold mb-2" id="emptyT">Carregant...</h3>
        <p class="mb-6" style="color:var(--muted);max-width:400px;margin:0 auto" id="emptyP">Connectant amb la base de dades.</p>
        <button class="bp hidden" id="emptyBtn"><i class="fa-solid fa-plus"></i><span>Publicar el meu primer llibre</span></button>
      </div>
    </section>
  </main>

  <footer class="relative z-10 text-center py-8 border-t-2" style="border-color:var(--accent-l)">
    <p class="text-sm font-bold" style="color:var(--muted)">🌴 Club de Lectura d'Estiu — On cada llibre troba el seu lector 📖</p>
  </footer>

  <script>
    /* ═══════════════════════════════════════
       CONFIGURACIÓ JSONBIN.IO I SEGURETAT
       ═══════════════════════════════════════ */
    const BIN_ID = '6a3fbabef5f4af5e2938ab91';
    const API_KEY = '$2a$10$N8lGSvGQS4z2rtLeWsgWTecEAHAoJo8iX1O5g4KN8R2teYN5k1/1.';
    const SYNC_MS = 12000;
    
    // Contrasenyes
    const PASS_ACCESS = '2015denia';
    const PASS_ADMIN = 'pepdenia';
    /* ═══════════════════════════════════════ */

    const API_URL = `https://api.jsonbin.io/v3/b/${BIN_ID}`;
    const HEADERS = { 'Content-Type': 'application/json', 'X-Master-Key': API_KEY };

    /* ── Estat global ── */
    let P = [], filter = 'all', rating = 0, imgData = null, syncing = false, lastETag = null;
    let userName = localStorage.getItem('bcUser') || '';
    const U = userName || 'u_' + Math.random().toString(36).slice(2, 7);
    if (!userName) localStorage.setItem('bcUser', U);

    /* ── Partícules d'estiu ── */
    !function () {
      const c = document.getElementById('ptc'), ic = ['fa-sun', 'fa-umbrella-beach', 'fa-water', 'fa-ice-cream', 'fa-star'];
      for (let i = 0; i < 6; i++) {
        const e = document.createElement('i');
        e.className = `fa-solid ${ic[i % ic.length]} fp`;
        e.style.left = Math.random() * 100 + '%';
        e.style.animationDelay = Math.random() * 25 + 's';
        e.style.animationDuration = (20 + Math.random() * 20) + 's';
        c.appendChild(e);
      }
    }();

    /* ── Utilitats ── */
    const $ = s => document.querySelector(s), $$ = s => document.querySelectorAll(s);
    const esc = t => { const d = document.createElement('div'); d.textContent = t; return d.innerHTML; };
    const uid = () => Date.now().toString(36) + Math.random().toString(36).slice(2, 7);

    function timeAgo(d) {
      const s = Math.floor((Date.now() - new Date(d)) / 1000);
      if (s < 60) return 'Ara mateix';
      const m = Math.floor(s / 60); if (m < 60) return `Fa ${m} min`;
      const h = Math.floor(m / 60); if (h < 24) return `Fa ${h}h`;
      const dd = Math.floor(h / 24); if (dd < 7) return `Fa ${dd}d`;
      return new Date(d).toLocaleDateString('ca-ES', { day: 'numeric', month: 'short' });
    }

    function sColor(s) {
      let h = 0; for (let i = 0; i < s.length; i++) h = s.charCodeAt(i) + ((h << 5) - h);
      return ['#ff7675', '#00b894', '#fdcb6e', '#e17055', '#0984e3', '#6c5ce7', '#00cec9', '#fd79a8', '#e84393', '#55efc4', '#fab1a0', '#81ecec', '#74b9ff', '#a29bfe', '#dfe6e9', '#636e72'][Math.abs(h) % 16];
    }

    function initials(n) {
      const p = n.trim().split(/\s+/);
      return p.length >= 2 ? (p[0][0] + p[p.length - 1][0]).toUpperCase() : n.substring(0, 2).toUpperCase();
    }

    function starsHTML(r) {
      let h = ''; for (let i = 1; i <= 5; i++) h += `<i class="fa-solid fa-star text-sm" style="color:${i <= r ? '#fdcb6e' : 'var(--border)'}"></i>`; return h;
    }

    function setSync(s) { $('#syncDot').className = 'sd ' + s; }

    function toast(msg, t = 'ok') {
      const e = document.createElement('div'); e.className = `tt ${t}`;
      const ic = t === 'ok' ? 'fa-check-circle' : t === 'er' ? 'fa-exclamation-circle' : 'fa-info-circle';
      e.innerHTML = `<i class="fa-solid ${ic} mr-2"></i>${msg}`;
      $('#toasts').appendChild(e); setTimeout(() => e.remove(), 3000);
    }

    /* ═══════════════════════════════════════
       PORTA D'ACCÉS
       ═══════════════════════════════════════ */
    function checkAccess() {
      if (sessionStorage.getItem('bcAuth') === 'true') {
        $('#accessGate').style.display = 'none';
        initApp();
      } else {
        $('#accessGate').style.display = 'flex';
        document.body.style.overflow = 'hidden';
        setTimeout(() => $('#accessPass').focus(), 100);
      }
    }

    $('#accessBtn').addEventListener('click', doAccess);
    $('#accessPass').addEventListener('keydown', e => { if (e.key === 'Enter') doAccess(); });

    function doAccess() {
      const val = $('#accessPass').value;
      if (val === PASS_ACCESS) {
        sessionStorage.setItem('bcAuth', 'true');
        $('#accessGate').style.display = 'none';
        document.body.style.overflow = '';
        initApp();
      } else {
        $('#accessErr').classList.remove('hidden');
        $('#accessPass').value = '';
        $('#accessPass').focus();
      }
    }

    /* ═══════════════════════════════════════
       JSONBIN — LLEGIR I ESCRIBRE
       ═══════════════════════════════════════ */
    async function fetchPosts() {
      try {
        const h = { 'X-Master-Key': API_KEY };
        if (lastETag) h['If-None-Match'] = lastETag;
        const res = await fetch(API_URL + '/latest', { headers: h });
        if (res.status === 304) { setSync('ok'); return true; }
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const etag = res.headers.get('ETag'); if (etag) lastETag = etag;
        const rec = (await res.json()).record;
        if (!Array.isArray(rec)) {
          const ir = await fetch(API_URL, { method: 'PUT', headers: HEADERS, body: JSON.stringify([]) });
          if (ir.ok) { const ie = ir.headers.get('ETag'); if (ie) lastETag = ie; P = []; } else throw new Error('Init fail');
        } else { P = rec; }
        setSync('ok'); render(); stats(); return true;
      } catch (err) { console.error(err); setSync('err'); return false; }
    }

    async function pushPosts() {
      if (syncing) return false; syncing = true; setSync('ld');
      try {
        const res = await fetch(API_URL, { method: 'PUT', headers: HEADERS, body: JSON.stringify(P) });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const etag = res.headers.get('ETag'); if (etag) lastETag = etag;
        setSync('ok'); syncing = false; return true;
      } catch (err) { console.error(err); setSync('err'); syncing = false; return false; }
    }

    async function syncApply(fn) {
      if (syncing) { await new Promise(r => setTimeout(r, 600)); return syncApply(fn); }
      await fetchPosts(); fn(P); const ok = await pushPosts(); if (ok) { render(); stats(); } return ok;
    }

    /* ═══════════════════════════════════════
       MODALS
       ═══════════════════════════════════════ */
    function openModal(id) { $('#'+id).style.display='flex'; document.body.style.overflow='hidden'; }
    function closeModal(id) { $('#'+id).style.display='none'; document.body.style.overflow=''; }

    $('#btnNew').addEventListener('click', function () {
      resetForm(); $('#fName').value = localStorage.getItem('bcUserName') || '';
      openModal('mCreate');
      setTimeout(() => { if(!$('#fName').value) $('#fName').focus(); else $('#fTitle').focus(); }, 150);
    });
    $('#btnCloseModal').addEventListener('click', () => closeModal('mCreate'));
    $('#btnCloseImg').addEventListener('click', () => closeModal('mImg'));
    
    document.addEventListener('keydown', e => {
      if (e.key !== 'Escape') return;
      if ($('#mImg').style.display !== 'none') closeModal('mImg');
      else if ($('#mCreate').style.display !== 'none') closeModal('mCreate');
    });
    $('#mCreate').addEventListener('click', e => { if (e.target === $('#mCreate')) closeModal('mCreate'); });
    $('#mImg').addEventListener('click', e => { if (e.target === $('#mImg')) closeModal('mImg'); });
    $('#emptyBtn').addEventListener('click', () => $('#btnNew').click());

    /* ═══════════════════════════════════════
       ESTRELLES
       ═══════════════════════════════════════ */
    const starEls = $$('#stars .s');
    function setStars(v) { rating = v; starEls.forEach(s => s.classList.toggle('on', +s.dataset.v <= v)); }
    $('#stars').addEventListener('click', e => { const s = e.target.closest('.s'); if (s) setStars(+s.dataset.v); });
    $('#stars').addEventListener('mouseover', e => { const s = e.target.closest('.s'); if(!s) return; const v=+s.dataset.v; starEls.forEach(x => x.classList.toggle('hov', +x.dataset.v <= v)); });
    $('#stars').addEventListener('mouseout', () => starEls.forEach(s => s.classList.remove('hov')));

    /* ═══════════════════════════════════════
       IMATGE
       ═══════════════════════════════════════ */
    $('#fImg').addEventListener('change', e => { if (e.target.files[0]) processImage(e.target.files[0]); });
    $('#uZone').addEventListener('dragover', e => { e.preventDefault(); $('#uZone').classList.add('dov'); });
    $('#uZone').addEventListener('dragleave', () => $('#uZone').classList.remove('dov'));
    $('#uZone').addEventListener('drop', e => { e.preventDefault(); $('#uZone').classList.remove('dov'); if(e.dataTransfer.files[0]) processImage(e.dataTransfer.files[0]); });

    function processImage(file) {
      if (!file.type.startsWith('image/')) return toast('Només es permeten imatges', 'er');
      if (file.size > 3 * 1024 * 1024) return toast("La imatge no pot superar 3MB", 'er');
      const reader = new FileReader();
      reader.onload = e => {
        const img = new Image();
        img.onload = () => {
          const c = document.createElement('canvas'), mx = 600; let w = img.width, h = img.height;
          if (w > mx || h > mx) { if (w > h) { h = h * mx / w; w = mx; } else { w = w * mx / h; h = mx; } }
          c.width = Math.max(1, Math.round(w)); c.height = Math.max(1, Math.round(h));
          c.getContext('2d').drawImage(img, 0, 0, c.width, c.height);
          imgData = c.toDataURL('image/jpeg', 0.5);
          $('#pvImg').src = imgData; $('#uPh').classList.add('hidden'); $('#uPv').classList.remove('hidden'); $('#errImg').classList.add('hidden');
        };
        img.src = e.target.result;
      };
      reader.readAsDataURL(file);
    }

    /* ═══════════════════════════════════════
       FORMULARI
       ═══════════════════════════════════════ */
    $('#fContent').addEventListener('input', function () { $('#cc').textContent = this.value.length; });
    $('#fName').addEventListener('input', function () { if (this.value.trim()) $('#errName').classList.add('hidden'); });
    $('#fTitle').addEventListener('input', function () { if (this.value.trim()) $('#errTitle').classList.add('hidden'); });
    $('#fContent').addEventListener('input', function () { if (this.value.trim()) $('#errContent').classList.add('hidden'); });

    function resetForm() {
      $('#pForm').reset(); rating = 0; imgData = null; setStars(0);
      $('#uPh').classList.remove('hidden'); $('#uPv').classList.add('hidden'); $('#cc').textContent = '0';
      $$('#pForm .text-xs[id^="err"]').forEach(e => e.classList.add('hidden'));
      const btn = $('#submitBtn'); btn.disabled = false; btn.innerHTML = '<i class="fa-solid fa-paper-plane"></i><span>Publicar la meua opinió</span>';
    }

    $('#pForm').addEventListener('submit', async function (e) {
      e.preventDefault();
      const name = $('#fName').value.trim(), title = $('#fTitle').value.trim(), author = $('#fAuthor').value.trim(), content = $('#fContent').value.trim();
      let valid = true;
      if (!name) { $('#errName').classList.remove('hidden'); valid = false; } else $('#errName').classList.add('hidden');
      if (!title) { $('#errTitle').classList.remove('hidden'); valid = false; } else $('#errTitle').classList.add('hidden');
      if (!imgData) { $('#errImg').classList.remove('hidden'); valid = false; } else $('#errImg').classList.add('hidden');
      if (!content) { $('#errContent').classList.remove('hidden'); valid = false; } else $('#errContent').classList.add('hidden');
      if (!valid) return toast('Completa tots els camps obligatoris', 'er');

      const btn = $('#submitBtn'); btn.disabled = true; btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i><span>Guardant al núvol...</span>';
      localStorage.setItem('bcUserName', name); userName = name;

      const newPost = { id: uid(), author: name, bookTitle: title, bookAuthor: author, rating, image: imgData, content, likes: [], comments: [], createdAt: new Date().toISOString() };
      const ok = await syncApply(posts => { posts.unshift(newPost); });

      if (ok) { closeModal('mCreate'); resetForm(); toast('La teua opinió s\'ha publicat correctament!'); }
      else { toast('Error al guardar. Torna a intentar-ho.', 'er'); btn.disabled = false; btn.innerHTML = '<i class="fa-solid fa-paper-plane"></i><span>Publicar la meua opinió</span>'; }
    });

    /* ═══════════════════════════════════════
       FILTRES
       ═══════════════════════════════════════ */
    $('#filters').addEventListener('click', e => { const b = e.target.closest('.fc'); if(!b) return; filter = b.dataset.f; $$('.fc').forEach(c => c.classList.remove('on')); b.classList.add('on'); render(); });
    $('#search').addEventListener('input', render);

    /* ═══════════════════════════════════════
       RENDERITZAT
       ═══════════════════════════════════════ */
    function render() {
      const feed = $('#feed'), empty = $('#empty'), q = $('#search').value.toLowerCase().trim();
      let list = [...P];
      if (q) list = list.filter(p => p.bookTitle.toLowerCase().includes(q) || (p.bookAuthor && p.bookAuthor.toLowerCase().includes(q)) || p.author.toLowerCase().includes(q));
      if (filter === '5') list = list.filter(p => p.rating === 5);
      else if (filter === '4+') list = list.filter(p => p.rating >= 4);
      else if (filter === 'recent') list.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));
      else if (filter === 'popular') list.sort((a, b) => b.likes.length - a.likes.length);
      feed.querySelectorAll('.pc').forEach(el => el.remove());

      if (!list.length) {
        empty.classList.remove('hidden');
        const isLoading = !P.length && !q && filter === 'all';
        const hasFilter = q || filter !== 'all';
        if (isLoading) { $('#emptyT').textContent = 'Carregant...'; $('#emptyP').textContent = 'Connectant amb la base de dades.'; $('#emptyBtn').classList.add('hidden'); }
        else if (hasFilter) { $('#emptyT').textContent = 'Sense resultats'; $('#emptyP').textContent = 'No hem trobat publicacions amb aquests criteris.'; $('#emptyBtn').classList.add('hidden'); }
        else { $('#emptyT').textContent = 'Encara no hi ha publicacions'; $('#emptyP').textContent = 'Sigues el primer/a en compartir el llibre que llegeixes aquest estiu!'; $('#emptyBtn').classList.remove('hidden'); }
        return;
      }
      empty.classList.add('hidden');
      list.forEach((p, i) => { const el = buildCard(p); el.style.animationDelay = (i * 0.06) + 's'; feed.appendChild(el); });
    }

    function buildCard(p) {
      const el = document.createElement('article'); el.className = 'pc pe mb-6 overflow-hidden';
      const liked = p.likes.includes(U), savedName = localStorage.getItem('bcUserName') || 'Anònim';
      el.innerHTML = `
        <div class="flex flex-col sm:flex-row">
          <div class="sm:w-56 sm:min-w-[14rem] flex-shrink-0 cursor-pointer group" data-act="zoom" data-id="${p.id}">
            <img src="${p.image}" alt="Portada de ${esc(p.bookTitle)}" class="w-full h-52 sm:h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy">
          </div>
          <div class="flex-1 p-5 sm:p-6 flex flex-col">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-full flex items-center justify-center text-white text-sm font-bold flex-shrink-0" style="background:${sColor(p.author)}">${initials(p.author)}</div>
              <div class="flex-1 min-w-0">
                <p class="font-bold text-sm truncate">${esc(p.author)}</p>
                <p class="text-xs" style="color:var(--muted)">${timeAgo(p.createdAt)}</p>
              </div>
              <button data-act="del" data-id="${p.id}" class="del-btn w-8 h-8 rounded-full flex items-center justify-center hover:bg-red-50 transition" style="opacity:.3" title="Eliminar" aria-label="Eliminar publicació"><i class="fa-solid fa-trash-can text-xs" style="color:var(--accent)"></i></button>
            </div>
            <div class="mb-3">
              <h3 class="fd text-xl font-bold leading-tight mb-1">${esc(p.bookTitle)}</h3>
              ${p.bookAuthor ? `<p class="text-sm font-bold" style="color:var(--muted)">per ${esc(p.bookAuthor)}</p>` : ''}
              <div class="flex items-center gap-2 mt-2">${starsHTML(p.rating)}${p.rating ? `<span class="text-xs font-bold" style="color:var(--muted)">${p.rating}/5</span>` : ''}</div>
            </div>
            <p class="text-sm leading-relaxed flex-1 mb-4" style="opacity:.9">${esc(p.content)}</p>
            <div class="flex items-center gap-4 pt-3 border-t-2" style="border-color:var(--bg-deep)">
              <button data-act="like" data-id="${p.id}" class="lb flex items-center gap-1.5 text-sm font-bold ${liked ? 'on' : ''}" style="color:${liked ? 'var(--accent)' : 'var(--muted)'}" aria-label="M'agrada"><i class="fa-${liked ? 'solid' : 'regular'} fa-heart"></i><span>${p.likes.length || ''}</span></button>
              <button data-act="focus" data-id="${p.id}" class="flex items-center gap-1.5 text-sm font-bold hover:opacity-70" style="color:var(--muted)" aria-label="Comentar"><i class="fa-regular fa-comment"></i><span>${p.comments.length || ''}</span></button>
              <button data-act="zoom" data-id="${p.id}" class="flex items-center gap-1.5 text-sm font-bold hover:opacity-70 ml-auto" style="color:var(--muted)" aria-label="Ampliar"><i class="fa-solid fa-expand"></i><span class="hidden sm:inline">Ampliar</span></button>
            </div>
            <div class="mt-4">
              ${p.comments.length ? `<div class="space-y-3 mb-3 max-h-60 overflow-y-auto pr-1">${p.comments.map(c => commentHTML(p.id, c)).join('')}</div>` : ''}
              <div class="flex gap-2 items-start">
                <div class="w-8 h-8 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0 mt-0.5" style="background:${sColor(savedName)}">${initials(savedName)}</div>
                <div class="flex-1 flex gap-2">
                  <input type="text" class="inp text-sm py-2" placeholder="Escriu un comentari..." id="ci-${p.id}" maxlength="300">
                  <button data-act="comment" data-id="${p.id}" class="bs flex-shrink-0 px-3 py-2" aria-label="Enviar"><i class="fa-solid fa-paper-plane text-xs"></i></button>
                </div>
              </div>
            </div>
          </div>
        </div>`;
      const delBtn = el.querySelector('.del-btn');
      el.addEventListener('mouseenter', () => delBtn.style.opacity = '1');
      el.addEventListener('mouseleave', () => delBtn.style.opacity = '.3');
      return el;
    }

    function commentHTML(pid, c) {
      return `<div class="ci py-2">
        <div class="flex items-center gap-2 mb-1">
          <div class="w-6 h-6 rounded-full flex items-center justify-center text-white text-[10px] font-bold" style="background:${sColor(c.author)}">${initials(c.author)}</div>
          <span class="text-xs font-bold">${esc(c.author)}</span>
          <span class="text-xs" style="color:var(--muted)">${timeAgo(c.createdAt)}</span>
          <button data-act="delcm" data-pid="${pid}" data-cid="${c.id}" class="ml-auto opacity-0 hover:opacity-100 transition-opacity text-xs" style="color:var(--accent)" aria-label="Eliminar"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <p class="text-sm ml-8" style="opacity:.9">${esc(c.text)}</p>
      </div>`;
    }

    /* ═══════════════════════════════════════
       ACCIONS DEL FEED (DELEGACIÓ)
       ═══════════════════════════════════════ */
    document.getElementById('feed').addEventListener('click', async function (e) {
      const btn = e.target.closest('[data-act]'); if (!btn) return;
      const act = btn.dataset.act, id = btn.dataset.id;

      if (act === 'like') {
        await syncApply(posts => { const p = posts.find(x => x.id === id); if(!p) return; const i = p.likes.indexOf(U); if(i===-1) p.likes.push(U); else p.likes.splice(i,1); });
      }
      else if (act === 'focus') {
        const inp = document.getElementById('ci-' + id); if(inp){ inp.focus(); inp.scrollIntoView({behavior:'smooth',block:'center'}); }
      }
      else if (act === 'zoom') {
        const p = P.find(x => x.id === id); if(!p) return; $('#fullImg').src = p.image; openModal('mImg');
      }
      else if (act === 'del') { promptAdmin(id, 'post'); }
      else if (act === 'comment') {
        const inp = document.getElementById('ci-' + id); if(!inp) return;
        const txt = inp.value.trim(); if(!txt) return toast('Escriu alguna cosa abans de comentar', 'er');
        const authorName = localStorage.getItem('bcUserName') || 'Anònim';
        const newComment = { id: uid(), author: authorName, text: txt, createdAt: new Date().toISOString() };
        await syncApply(posts => { const p = posts.find(x => x.id === id); if(p) p.comments.push(newComment); });
        toast('Comentari afegit!');
        setTimeout(() => { const i = document.getElementById('ci-' + id); if(i){ i.focus(); i.scrollIntoView({behavior:'smooth',block:'center'});} }, 100);
      }
      else if (act === 'delcm') { promptAdmin(btn.dataset.cid, 'comment', btn.dataset.pid); }
    });

    // Enter per enviar comentari
    document.getElementById('feed').addEventListener('keydown', e => {
      if (e.key === 'Enter' && e.target.id && e.target.id.startsWith('ci-')) {
        const id = e.target.id.replace('ci-', '');
        const btn = e.target.closest('.flex').querySelector('[data-act="comment"]');
        if (btn) btn.click();
      }
    });

    /* ═══════════════════════════════════════
       MODAL D'ADMINISTRADOR PER ELIMINAR
       ═══════════════════════════════════════ */
    function promptAdmin(targetId, type, parentId) {
      const overlay = document.createElement('div'); overlay.className = 'mo'; overlay.style.zIndex = '2000';
      const isPost = type === 'post';
      const p = isPost ? P.find(x => x.id === targetId) : null;
      
      overlay.innerHTML = `
        <div class="mc p-6 max-w-sm mx-4 text-center">
          <div class="w-16 h-16 mx-auto mb-4 rounded-full flex items-center justify-center" style="background:var(--accent-l)">
            <i class="fa-solid fa-shield-halved text-2xl" style="color:var(--accent)"></i>
          </div>
          <h3 class="fd text-xl font-bold mb-2">Zona d'Administració</h3>
          <p class="text-sm mb-4" style="color:var(--muted)">${isPost ? `Vols eliminar "${esc(p.bookTitle)}"?` : 'Vols eliminar aquest comentari?'}</p>
          <input type="password" id="adminPassInp" class="inp mb-2" placeholder="Contrasenya d'administrador..." autocomplete="off">
          <p class="pass-err hidden" id="adminErr">Contrasenya incorrecta!</p>
          <div class="flex gap-3 mt-4">
            <button class="flex-1 py-2.5 rounded-xl font-bold text-sm border-2 transition hover:bg-gray-50" style="border-color:var(--border);color:var(--muted)" id="adNo">Cancel·lar</button>
            <button class="flex-1 py-2.5 rounded-xl font-bold text-sm text-white transition" style="background:var(--accent)" id="adYes">Eliminar</button>
          </div>
        </div>`;
      
      document.body.appendChild(overlay);
      setTimeout(() => $('#adminPassInp').focus(), 100);
      overlay.addEventListener('click', e => { if (e.target === overlay) overlay.remove(); });
      overlay.querySelector('#adNo').onclick = () => overlay.remove();
      
      // Acció fer Enter
      overlay.querySelector('#adminPassInp').addEventListener('keydown', e => { if(e.key==='Enter') overlay.querySelector('#adYes').click(); });

      overlay.querySelector('#adYes').onclick = async function () {
        if ($('#adminPassInp').value !== PASS_ADMIN) {
          $('#adminErr').classList.remove('hidden');
          $('#adminPassInp').value = '';
          $('#adminPassInp').focus();
          return;
        }

        if (isPost) {
          await syncApply(posts => { const idx = posts.findIndex(x => x.id === targetId); if(idx!==-1) posts.splice(idx,1); });
          toast('Publicació eliminada');
        } else {
          await syncApply(posts => { 
            const p = posts.find(x => x.id === parentId); 
            if(p) p.comments = p.comments.filter(c => c.id !== targetId); 
          });
          toast('Comentari eliminat');
        }
        overlay.remove();
      };
    }

    /* ═══════════════════════════════════════
       ESTADÍSTIQUES
       ═══════════════════════════════════════ */
    function stats() {
      animNum('sB', P.length);
      animNum('sC', P.reduce((s, p) => s + p.comments.length, 0));
      animNum('sL', P.reduce((s, p) => s + p.likes.length, 0));
    }
    function animNum(id, target) {
      const el = document.getElementById(id), cur = parseInt(el.textContent) || 0;
      if (cur === target) return; const t0 = performance.now();
      (function tick(now) { const p = Math.min((now - t0) / 600, 1), ease = 1 - Math.pow(1 - p, 3); el.textContent = Math.round(cur + (target - cur) * ease); if(p<1) requestAnimationFrame(tick); })(t0);
    }

    /* ═══════════════════════════════════════
       INICI DE L'APLICACIÓ
       ═══════════════════════════════════════ */
    async function initApp() {
      let ok = await fetchPosts();
      if (!ok) {
        try {
          const res = await fetch(API_URL, { method: 'PUT', headers: HEADERS, body: JSON.stringify([]) });
          if (res.ok) { const etag = res.headers.get('ETag'); if (etag) lastETag = etag; P = []; setSync('ok'); render(); stats(); }
          else throw new Error('Fail');
        } catch (e2) {
          setSync('err'); $('#emptyT').textContent = 'Error de connexió';
          $('#emptyP').textContent = 'No s\'ha pogut connectar amb la base de dades. Revisa la teua connexió a internet.'; 
          $('#emptyBtn').classList.add('hidden'); $('#empty').classList.remove('hidden'); return;
        }
      }
      setInterval(fetchPosts, SYNC_MS);
    }

    // Arrancar la porta d'accés
    checkAccess();
  </script>
</body>
</html>
